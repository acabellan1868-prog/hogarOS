# ============================================================
# hogarOS — Variables de entorno (orquestador de todo el ecosistema)
# ============================================================
# Copia este archivo como .env y rellena los valores reales:
#   cp .env.example .env
#
# El archivo .env NUNCA se sube a git (está en .gitignore).
# Este archivo contiene las variables de TODOS los servicios,
# ya que hogarOS orquesta FiDo, ReDo, MediDo y Nginx desde
# un único docker-compose.yml.
# ============================================================

# ── Nginx / Home Assistant (domótica) ────────────────────────
# Token de larga duración de Home Assistant.
# Crear en: HA → Perfil → Seguridad → Tokens de acceso de larga duración
HA_TOKEN=

# ── ReDo — Red Doméstica ─────────────────────────────────────
# Rango de red local a escanear en formato CIDR (Enrutamiento entre Dominios sin Clases)
REDO_NETWORK=192.168.XX.0/24

# ── FiDo — Finanzas Domésticas ───────────────────────────────
# Topic privado de NTFY (intermediario de transporte) para recibir
# movimientos bancarios desde Tasker (app Android de automatización).
# Generar con: python -c "import secrets; print('fido-mov-' + secrets.token_hex(8))"
NTFY_TOPIC_FIDO=

# ID de la cuenta FiDo que se usará si el mensaje no especifica ninguna
NTFY_CUENTA_DEFAULT=1

# ── ReDo + MediDo — Alertas del ecosistema ───────────────────
# Topic privado de NTFY compartido por ReDo y MediDo para alertas del sistema
# (dispositivos desconocidos en la red, umbrales de CPU/RAM, etc.)
# Generar con: python -c "import secrets; print('hogaros-' + secrets.token_hex(4))"
NTFY_TOPIC_ALERTAS=

# ── MediDo — Proxmox (hipervisor de virtualización) ──────────
# IP o hostname del servidor Proxmox
PVE_HOST=

# Nombre del nodo Proxmox
PVE_NODE=

# ID del token de API (Interfaz de Programación) de Proxmox (formato: usuario@realm!nombre)
# Crear en: Proxmox → Datacenter → Permissions → API Tokens
PVE_TOKEN_ID=

# Secreto del token de API de Proxmox
PVE_TOKEN_SECRET=

# Verificar certificado SSL (Capa de Conexión Segura) del servidor Proxmox
PVE_VERIFY_SSL=false
